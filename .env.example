# ============================================================
# DEFENCE EQUIPMENT ACCOUNTABILITY SYSTEM
# .env.example — Copy this to .env before running
# Fill in YOUR actual values below (do NOT commit your .env)
# ============================================================

NODE_ENV=development
APP_NAME="Defence Equipment Accountability System"
APP_VERSION=1.0.0

# ─── PostgreSQL (Neon.tech) ───────────────────────────────────
DATABASE_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>/neondb?sslmode=require&channel_binding=require
DATABASE_DIRECT_URL=postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST_DIRECT>/neondb?sslmode=require&channel_binding=require
POSTGRES_HOST=<your-neon-host>
POSTGRES_PORT=5432
POSTGRES_DB=neondb
POSTGRES_USER=<your_db_user>
POSTGRES_PASSWORD=<your_db_password>
POSTGRES_SSL=true
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000

# ─── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=<your_redis_password>
REDIS_DB=0
REDIS_URL=redis://:<your_redis_password>@localhost:6380/0
REDIS_CACHE_TTL=120
REDIS_SESSION_TTL=604800
REDIS_RATE_LIMIT_TTL=900
REDIS_LOCATION_TTL=7200

# ─── Node.js Backend ──────────────────────────────────────────
BACKEND_PORT=5000
BACKEND_HOST=0.0.0.0
CORS_ORIGINS=http://localhost:3000,http://localhost:19006,exp://localhost:19000

# ─── JWT (generate strong random secrets for production!) ─────
JWT_ACCESS_SECRET=<generate_a_long_random_secret_here>
JWT_REFRESH_SECRET=<generate_a_different_long_random_secret>
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_ISSUER=deas.mil
JWT_AUDIENCE=deas-clients

# ─── Rate Limiting ────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000

# ─── File Uploads ─────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# ─── Email (Nodemailer) ───────────────────────────────────────
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=<your_smtp_username>
SMTP_PASS=<your_smtp_password>
EMAIL_FROM="DEAS System <noreply@deas.mil>"
EMAIL_ALERT_CC=admin@deas.mil

# ─── Python AI Service ────────────────────────────────────────
AI_SERVICE_HOST=ai-service
AI_SERVICE_PORT=8001
AI_SERVICE_URL=http://ai-service:8001
AI_SERVICE_TIMEOUT_MS=10000
EMBEDDING_MODEL=all-MiniLM-L6-v2
MODEL_PATH=./models

# ─── React Web (Vite) ─────────────────────────────────────────
VITE_API_URL=http://localhost:5000/api
VITE_SOCKET_URL=http://localhost:5000
VITE_APP_NAME="Defence Equipment Accountability System"
VITE_APP_VERSION=1.0.0
VITE_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# ─── Firebase (Web) ───────────────────────────────────────────
VITE_FIREBASE_API_KEY=<your_firebase_api_key>
VITE_FIREBASE_AUTH_DOMAIN=<your-project>.firebaseapp.com
VITE_FIREBASE_DATABASE_URL=https://<your-project>-default-rtdb.<region>.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=<your-firebase-project-id>
VITE_FIREBASE_STORAGE_BUCKET=<your-project>.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=<your_sender_id>
VITE_FIREBASE_APP_ID=<your_firebase_app_id>
VITE_FIREBASE_MEASUREMENT_ID=<your_measurement_id>

# ─── Firebase (Mobile/Expo) ───────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=<your_firebase_api_key>
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=<your-project>.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://<your-project>-default-rtdb.<region>.firebasedatabase.app
EXPO_PUBLIC_FIREBASE_PROJECT_ID=<your-firebase-project-id>
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=<your-project>.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<your_sender_id>
EXPO_PUBLIC_FIREBASE_APP_ID=<your_firebase_app_id>
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=<your_measurement_id>

# ─── Expo Mobile ──────────────────────────────────────────────
# Set this to your local machine's IP address (e.g., 192.168.1.100)
EXPO_PUBLIC_API_URL=http://<your_local_ip>:5000/api
EXPO_PUBLIC_SOCKET_URL=http://<your_local_ip>:5000
EXPO_PUBLIC_APP_NAME="DEAS Field"

# ─── Nginx ────────────────────────────────────────────────────
NGINX_HOST=localhost
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_DIR=./logs
LOG_MAX_FILES=30d
LOG_MAX_SIZE=20m
