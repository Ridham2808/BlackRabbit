# ============================================================
# BlackRabbit / DEAS — .gitignore
# ============================================================

# ─── Environment & Secrets (NEVER commit) ───────────────────
.env
.env.local
.env.production
.env.staging
.env.development
.env.test
# BUT keep the safe example template:
!.env.example

# Sub-project env files
backend/.env
backend/.env.*
mobile/.env
mobile/.env.*
web/.env
web/.env.*
!web/.env.example
!mobile/.env.example
!backend/.env.example

# ─── Node.js ─────────────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ─── Sub-project node_modules ────────────────────────────────
backend/node_modules/
web/node_modules/
mobile/node_modules/
db/node_modules/

# ─── Build Outputs ───────────────────────────────────────────
dist/
build/
.next/
out/
web-build/

# ─── Logs ────────────────────────────────────────────────────
*.log
logs/
backend/logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Uploads (user-generated data) ──────────────────────────
backend/uploads/
uploads/

# ─── Temporary / Scratch files ───────────────────────────────
tmp/
temp/
*.tmp
*.bak

# ─── Debug / One-off scripts (never needed in repo) ─────────
backend/check_demo.js
backend/db_schema.js
backend/debug_require.js
backend/fix_base_id.js
backend/fix_mobile_demo.js
backend/run_migration.js
backend/test_checkin.js
backend/test_checkout.js
backend/verify_feature_9.js

# ─── SSL / Certificates / Keys ───────────────────────────────
*.pem
*.key
*.crt
*.p8
*.p12
*.jks
*.mobileprovision
nginx/ssl/

# ─── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
.venv/
venv/
env/
ENV/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
ai-service/models/*.pkl
ai-service/models/*.joblib

# ─── Docker volumes / local data ─────────────────────────────
.docker/
postgres_data/
redis_data/

# ─── OS Generated ────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE / Editor ────────────────────────────────────────────
.vscode/settings.json
.vscode/*.code-workspace
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo
*.tsbuildinfo

# ─── Expo / React Native ─────────────────────────────────────
mobile/.expo/
mobile/android/
mobile/ios/
mobile/.kotlin/
mobile/*.apk
mobile/*.aab
mobile/expo-env.d.ts
.metro-health-check*

# ─── Audit / internal metadata ───────────────────────────────
logs/.*.json
